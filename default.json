{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":enablePreCommit",
    "helpers:pinGitHubActionDigests",
    "github>home-operations/renovate-presets//policies/semanticCommits.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/annotated.json5#1.3.1",
    "local>greyrock-labs/renovate-config:pr-labels"
  ],
  "timezone": "America/New_York",
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "commitBodyTable": true,
  "rebaseWhen": "auto",
  "renovate-config": {
    "managerFilePatterns": [
      "/\\.renovate\\/.*\\.json5?$/"
    ]
  },
  "platformCommit": "enabled"
}
